# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1256, check Pipfile.lock into git and use deps from there.
#   However, if you're developing a library on github, you should ignore Pipfile.lock.
# Pipfile.lock

# poetry
#   Similarly, check poetry.lock into git and use deps from there.
# poetry.lock

# pdm
#   Similarly, check pdm.lock into git and use deps from there.
# pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
python-*/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site/


.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static analyzer
.pytype/

# Cython debug symbols
cython_debug/

# OS X metadata
.DS_Store
.AppleDouble
.LSOverride

# Icon files
Icon

